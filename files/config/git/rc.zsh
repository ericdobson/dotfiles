#!/usr/bin/env zsh

# Sourced from zshrc. Keep this file limited to interactive shell behavior.
# Keep network work and expensive startup logic out unless there is a concrete reason.

alias bls='git ls'
alias brn='git brn'
alias cm='git commit'
alias cma='git commit -a'
alias co='git checkout'
alias com='git checkout main'
alias gd='git diff'
alias gp='git push'
alias gs='git status'
alias gss='git status --short'
